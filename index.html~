</main>

<script>
/* ════ STATE ════ */
var rentMode='s8';
function setRentMode(m){
  rentMode=m;
  var bm=$('btn-market'), bs=$('btn-s8'), lbl=$('rent-active-label');
  bm.className='rent-btn'+(m==='market'?' active-market':'');
  bs.className='rent-btn'+(m==='s8'?' active-s8':'');
  lbl.innerHTML=m==='s8'
    ?'<span style="background:var(--green-lt);color:var(--green);padding:2px 10px;border-radius:6px;">✓ חישוב לפי Section 8</span>'
    :'<span style="background:var(--surface2);color:var(--text2);padding:2px 10px;border-radius:6px;">✓ חישוב לפי שכירות שוק</span>';
  render();
}

/* ════ UTILS ════ */
var $=function(id){return document.getElementById(id);};
function gn(id){var v=parseFloat($(id)&&$(id).value);return isNaN(v)?0:v;}
function gs(id){return $(id)?$(id).value:'';}
function fmt(n,d){d=d||0;return Number(n).toLocaleString('en-US',{minimumFractionDigits:d,maximumFractionDigits:d});}
function fmtK(n){
  var a=Math.abs(n);
  var sign=n<0?'-':'';
  if(a>=1e6)return sign+'$'+(a/1e6).toFixed(2)+'M';
  if(a>=1e3)return sign+'$'+(a/1e3).toFixed(0)+'k';
  return sign+'$'+fmt(a);
}
function fmtMo(n){/* format small monthly values */
  var a=Math.abs(n);
  return (n<0?'-':'')+'$'+fmt(Math.round(a));
}
function fmtILS(usd,ils){var s=usd*ils,a=Math.abs(s);if(a>=1e6)return(s>=0?'':'−')+'₪'+(a/1e6).toFixed(2)+'M';return(s>=0?'':'−')+'₪'+fmt(Math.round(a));}
function hex2rgba(h,a){var r=parseInt(h.slice(1,3),16),g=parseInt(h.slice(3,5),16),b=parseInt(h.slice(5,7),16);return 'rgba('+r+','+g+','+b+','+a+')';}
function daysUntil(ds){var d=new Date(ds),n=new Date();return Math.max(0,Math.round((d-n)/86400000));}
function niceMax(v){/* round up to nice number */
  if(v===0) return 10;
  var mag=Math.pow(10,Math.floor(Math.log10(Math.abs(v))));
  return Math.ceil(v/mag)*mag;
}
function niceMin(v){
  if(v>=0) return 0;
  var mag=Math.pow(10,Math.floor(Math.log10(Math.abs(v))));
  return Math.floor(v/mag)*mag;
}

/* ════ SHPITZER ════ */
function calcShpitzer(balance,annualRate,matDateStr){
  var results=[];
  if(!balance||!annualRate||!matDateStr)return results;
  var r=annualRate/100/12;
  var totalMonths=Math.round(daysUntil(matDateStr)/30.4375);
  if(totalMonths<=0)totalMonths=360;
  var M=r===0?balance/totalMonths:balance*(r*Math.pow(1+r,totalMonths))/(Math.pow(1+r,totalMonths)-1);
  var bal=balance,annP=0,annI=0;
  for(var m=1;m<=Math.min(totalMonths,15*12);m++){
    var ip=bal*r,pp=Math.min(M-ip,bal);
    bal-=pp;annP+=pp;annI+=ip;
    if(m%12===0){
      results.push({year:m/12,balance:Math.max(0,Math.round(bal)),annualPrin:Math.round(annP),annualInt:Math.round(annI),monthlyPayment:Math.round(M)});
      annP=0;annI=0;
    }
  }
  return results;
}

/* ════ PROJECTION ════ */
function calcData(){
  var purchase  =gn('f-purchase');
  var market    =gn('f-market');
  var entry     =gn('f-entry');
  var loanBal   =gn('f-loan-bal');
  var rate      =gn('f-rate');
  var matDate   =gs('f-maturity');
  var taxes     =gn('f-taxes');
  var insurance =gn('f-insurance');
  var hoa       =gn('f-hoa');
  var capex     =gn('f-capex');
  var other     =gn('f-other');
  var rentMarket=gn('f-rent-market');
  var rentS8    =gn('f-rent-s8');
  var rentGrowth=gn('f-rent-growth')/100;
  var ils       =gn('f-ils');
  var appr      =gn('f-appr')/100;
  var snpR      =gn('f-snp')/100;
  var baseRent  =rentMode==='s8'?rentS8:rentMarket;

  var shp=calcShpitzer(loanBal,rate,matDate);

  /* sidebar shpitzer display */
  if(shp.length>0){
    var mp=shp[0].monthlyPayment,int1=shp[0].annualInt/12,pr1=mp-int1;
    $('shp-payment').textContent='$'+fmt(Math.round(mp));
    $('shp-int1').textContent='$'+fmt(Math.round(int1));
    $('shp-prin1').textContent='$'+fmt(Math.round(pr1));
    var ti=0;shp.forEach(function(s){ti+=s.annualInt;});
    $('shp-total-int').textContent='$'+fmt(Math.round(ti));
  }

  var rows=[];
  var val=market||purchase;
  var curRent=baseRent;
  var cumCF=0;

  /* ── S&P: entry fee invested at year 0, compounds each year ──
     snpVal[yr] = entry * (1+snpR)^yr
     gain = snpVal - entry  (pure profit above initial stake) */

  for(var yr=0;yr<=15;yr++){
    var shpYr   =shp[yr-1]||null;
    var annPrin =shpYr?shpYr.annualPrin:0;
    var annInt  =shpYr?shpYr.annualInt:0;
    var monthlyPI=shpYr?shpYr.monthlyPayment:0;
    var bal     =yr===0?loanBal:(shp[yr-1]?shp[yr-1].balance:Math.max(0,loanBal-annPrin));

    var piti    =monthlyPI+taxes+insurance+hoa+capex+other;
    var monthCF =curRent-piti;
    var annCF   =monthCF*12;
    var appGain =val*appr;
    /* ── CORRECT EQUITY: property value MINUS remaining loan balance ──
       Entry Fee is the cash paid to buy in — it is NOT deducted from equity
       Equity = Current Value − Loan Balance */
    var equity  =val-bal;
    /* ── S&P gain on entry fee ── */
    var snpGain =entry*(Math.pow(1+snpR,yr)-1);  // pure gain, starts at 0
    var roe     =yr===0?0:((annCF+annPrin+appGain)/(entry||1))*100;

    rows.push({
      year:yr, balance:Math.round(bal), value:Math.round(val),
      equity:Math.round(equity), cumCF:Math.round(cumCF),
      snpGain:Math.round(snpGain),
      annCF:Math.round(annCF), annPrin:Math.round(annPrin),
      annInt:Math.round(annInt), appGain:Math.round(appGain),
      roe:parseFloat(roe.toFixed(2)),
      monthCF:Math.round(monthCF), piti:Math.round(piti),
      monthlyPI:Math.round(monthlyPI),
      curRent:Math.round(curRent)
    });

    if(yr>0){val*=(1+appr);cumCF+=annCF;}
    curRent*=(1+rentGrowth);
    if(yr===0)cumCF=0;
  }

  return{rows,entry,ils,shp,purchase,market:market||purchase,loanBal,
    annCF:rows[1]?rows[1].annCF:0,
    annPrin:rows[1]?rows[1].annPrin:0,
    monthCF:rows[1]?rows[1].monthCF:0,
    piti:rows[1]?rows[1].piti:0,
    rentGrowth,baseRent
  };
}

/* ══════════════════════════
   CANVAS ENGINE
══════════════════════════ */
function setupCanvas(id,h){
  var c=$(id);if(!c)return null;
  var dpr=window.devicePixelRatio||1;
  var W=c.parentElement.clientWidth-32;
  c.style.width=W+'px';c.style.height=h+'px';
  c.width=W*dpr;c.height=h*dpr;
  var ctx=c.getContext('2d');ctx.scale(dpr,dpr);
  return{ctx,W,H:h};
}
function drawGrid(ctx,pad,iw,ih,maxV,minV){
  var range=maxV-minV||1;
  for(var g=0;g<=4;g++){
    var gy=pad.top+ih-(g/4)*ih;
    ctx.strokeStyle='#e2e8f0';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(pad.left,gy);ctx.lineTo(pad.left+iw,gy);ctx.stroke();
    var gv=minV+(g/4)*range;
    var lbl;
    if(Math.abs(gv)>=1000) lbl=(gv<0?'-':'')+' $'+(Math.abs(gv)/1000).toFixed(0)+'k';
    else lbl=(gv<0?'-$':'$')+Math.abs(Math.round(gv));
    ctx.fillStyle='#94a3b8';ctx.font='9px DM Mono,monospace';ctx.textAlign='right';
    ctx.fillText(lbl,pad.left-4,gy+4);
  }
}
function drawXLabels(ctx,pad,iw,H,labels){
  ctx.fillStyle='#94a3b8';ctx.font='9px DM Mono,monospace';ctx.textAlign='center';
  labels.forEach(function(l,i){
    if(labels.length<=16||i%3===0)
      ctx.fillText(l,pad.left+(i/(labels.length-1||1))*iw,H-6);
  });
}
function drawLineSeries(ctx,pad,iw,ih,data,maxV,minV,series){
  var n=data.length;
  var range=maxV-minV||1;
  function xp(i){return pad.left+(i/(n-1||1))*iw;}
  function yp(v){return pad.top+ih-((v-minV)/range)*ih;}
  /* zero line */
  if(minV<0&&maxV>0){
    var zy=yp(0);
    ctx.strokeStyle='rgba(148,163,184,.4)';ctx.lineWidth=1;ctx.setLineDash([3,3]);
    ctx.beginPath();ctx.moveTo(pad.left,zy);ctx.lineTo(pad.left+iw,zy);ctx.stroke();
    ctx.setLineDash([]);
  }
  series.forEach(function(s){
    var grad=ctx.createLinearGradient(0,pad.top,0,pad.top+ih);
    grad.addColorStop(0,hex2rgba(s.color,.15));
    grad.addColorStop(1,hex2rgba(s.color,0));
    ctx.beginPath();
    data.forEach(function(d,i){i===0?ctx.moveTo(xp(i),yp(d[s.key])):ctx.lineTo(xp(i),yp(d[s.key]));});
    ctx.save();
    ctx.lineTo(xp(n-1),yp(Math.max(minV,0)));
    ctx.lineTo(xp(0),yp(Math.max(minV,0)));
    ctx.closePath();ctx.fillStyle=grad;ctx.fill();ctx.restore();
    ctx.beginPath();
    data.forEach(function(d,i){i===0?ctx.moveTo(xp(i),yp(d[s.key])):ctx.lineTo(xp(i),yp(d[s.key]));});
    ctx.strokeStyle=s.color;ctx.lineWidth=2.5;ctx.lineJoin='round';ctx.stroke();
    [5,10,15].forEach(function(yr){
      if(yr<data.length){
        ctx.beginPath();ctx.arc(xp(yr),yp(data[yr][s.key]),4,0,Math.PI*2);
        ctx.fillStyle=s.color;ctx.fill();
        ctx.strokeStyle='#fff';ctx.lineWidth=1.5;ctx.stroke();
      }
    });
  });
}
function registerHover(canvasId,wrapId,crossId,pad,data,series){
  var c=$(canvasId);if(!c)return;
  function onMove(ex,ey){
    var rect=c.getBoundingClientRect();
    var mx=ex-rect.left;
    var iw=rect.width-pad.left-pad.right;
    var ih=rect.height-pad.top-pad.bottom;
    if(mx<pad.left||mx>pad.left+iw){hideTT();return;}
    var n=data.length;
    var idx=Math.round(((mx-pad.left)/iw)*(n-1));
    idx=Math.max(0,Math.min(n-1,idx));
    var d=data[idx];
    var cr=$(crossId);
    if(cr){cr.style.display='block';cr.style.left=(pad.left+(idx/(n-1||1))*iw)+'px';cr.style.top=pad.top+'px';cr.style.height=ih+'px';}
    var title=d.year!==undefined?'שנה '+d.year:(d.label||String(idx));
    var html='<div class="tt-title">'+title+'</div>';
    series.forEach(function(s){
      var v=d[s.key];
      var vStr=s.pct?v.toFixed(1)+'%':s.mo?fmtMo(v):fmtK(v);
      html+='<div class="tt-row"><span class="tt-label"><span class="tt-dot" style="background:'+s.color+'"></span>'+s.label+'</span><span class="tt-val" style="color:'+s.color+';">'+vStr+'</span></div>';
    });
    var tt=$('tt');tt.innerHTML=html;tt.classList.add('visible');
    var tl=ex+14,tt2=ey-20;
    if(tl+190>window.innerWidth)tl=ex-204;
    if(tt2+110>window.innerHeight)tt2=window.innerHeight-120;
    tt.style.left=tl+'px';tt.style.top=tt2+'px';
  }
  function onLeave(){hideTT();var cr=$(crossId);if(cr)cr.style.display='none';}
  c.onmousemove=function(e){onMove(e.clientX,e.clientY);};
  c.onmouseleave=onLeave;
}
function hideTT(){var tt=$('tt');if(tt)tt.classList.remove('visible');}

/* generic line chart */
function drawLineChart(id,wrapId,crossId,data,series,h){
  h=h||210;
  var s=setupCanvas(id,h);if(!s)return;
  var ctx=s.ctx,W=s.W,H=s.H;
  var pad={top:14,right:12,bottom:22,left:58};
  var iw=W-pad.left-pad.right,ih=H-pad.top-pad.bottom;
  var maxV=0,minV=0;
  data.forEach(function(d){series.forEach(function(sr){maxV=Math.max(maxV,d[sr.key]);minV=Math.min(minV,d[sr.key]);});});
  maxV=niceMax(maxV*1.05);
  minV=niceMin(minV*1.05);
  drawGrid(ctx,pad,iw,ih,maxV,minV);
  drawXLabels(ctx,pad,iw,H,data.map(function(d){return d.year!==undefined?d.year:(d.label||'');}));
  drawLineSeries(ctx,pad,iw,ih,data,maxV,minV,series);
  registerHover(id,wrapId,crossId,pad,data,series);
}

/* amortization stacked bar */
function drawAmort(id,wrapId,crossId,data){
  var s=setupCanvas(id,190);if(!s)return;
  var ctx=s.ctx,W=s.W,H=s.H;
  var pad={top:14,right:12,bottom:22,left:58};
  var iw=W-pad.left-pad.right,ih=H-pad.top-pad.bottom;
  var maxV=0;data.forEach(function(d){maxV=Math.max(maxV,d.annualPrin+d.annualInt);});
  maxV=niceMax(maxV*1.05)||1;
  for(var g=0;g<=4;g++){
    var gy=pad.top+ih-(g/4)*ih;
    ctx.strokeStyle='#e2e8f0';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(pad.left,gy);ctx.lineTo(pad.left+iw,gy);ctx.stroke();
    ctx.fillStyle='#94a3b8';ctx.font='9px DM Mono,monospace';ctx.textAlign='right';
    ctx.fillText('$'+(Math.round((g/4)*maxV/1000))+'k',pad.left-4,gy+4);
  }
  var n=data.length;
  var bw=Math.max(6,(iw/n)*0.58);
  data.forEach(function(d,i){
    var cx=pad.left+(n>1?(i/(n-1))*iw:iw/2),x=cx-bw/2;
    var ih2=(d.annualInt/maxV)*ih,iy=pad.top+ih-ih2;
    rr(ctx,x,iy,bw,ih2,[0,0,0,0],'#f43f5e');
    var ph2=(d.annualPrin/maxV)*ih,py=iy-ph2;
    rr(ctx,x,py,bw,ph2,[3,3,0,0],'#2563eb');
    ctx.fillStyle='#94a3b8';ctx.font='9px DM Mono,monospace';ctx.textAlign='center';
    ctx.fillText('Y'+d.year,cx,H-6);
  });
  registerHover(id,wrapId,crossId,pad,data,[
    {key:'annualPrin',label:'קרן שנתית',color:'#2563eb'},
    {key:'annualInt', label:'ריבית שנתית',color:'#f43f5e'},
    {key:'balance',   label:'יתרת חוב',color:'#94a3b8'}
  ]);
}
function rr(ctx,x,y,w,h2,radii,fill){
  if(h2<=0||w<=0)return;
  var tl=radii[0],tr=radii[1];
  ctx.beginPath();
  ctx.moveTo(x+tl,y);ctx.lineTo(x+w-tr,y);ctx.quadraticCurveTo(x+w,y,x+w,y+tr);
  ctx.lineTo(x+w,y+h2);ctx.lineTo(x,y+h2);ctx.lineTo(x,y+tl);
  ctx.quadraticCurveTo(x,y,x+tl,y);ctx.closePath();
  ctx.fillStyle=fill;ctx.fill();
}

/* ════ RENDER ════ */
function render(){
  var proj=calcData();
  var rows=proj.rows,entry=proj.entry,ils=proj.ils;
  var annCF=proj.annCF,annPrin=proj.annPrin;
  var monthCF=proj.monthCF,piti=proj.piti;
  var r1=rows[1]||rows[0];
  var rentGrowth=proj.rentGrowth;
  var rentLabel=rentMode==='s8'?'Section 8':'שוק';

  /* HEADER */
  var addr=gs('f-address')||'—';
  var yBuilt=gs('f-year-built')||'—';
  var mktVal=gn('f-market')||gn('f-purchase')||1;
  var ltvPct=((gn('f-loan-bal')/mktVal)*100).toFixed(1);
  var ltvNum=parseFloat(ltvPct);
  var ltvCol=ltvNum>90?'#e11d48':ltvNum>80?'#d97706':'#059669';
  var ltvBg=ltvNum>90?'#fff1f2':ltvNum>80?'#fffbeb':'#ecfdf5';
  var cfCol=monthCF>=0?'#059669':'#e11d48';
  var matDate=gs('f-maturity');
  var matDays=matDate?daysUntil(matDate):0;
  var matYrs=(matDays/365).toFixed(1);
  var progPct=Math.max(0,Math.min(100,100-(matDays/10950)*100));

  $('dash-hdr').innerHTML=
    '<div class="dash-hdr">'+
      '<div>'+
        '<h1>'+addr+'</h1>'+
        '<div class="sub">שנת בנייה: '+yBuilt+' · Entry Fee: '+fmtK(entry)+' · PITI: $'+fmt(piti)+'/mo · שכירות: '+rentLabel+' ('+fmtMo(proj.baseRent)+')</div>'+
        (matDate?'<div class="maturity-bar"><span class="mat-label">פירעון:</span><span class="mat-val">'+matDate+' · '+matYrs+' שנים</span><div class="mat-prog"><div class="mat-prog-inner" style="width:'+progPct+'%"></div></div></div>':'')+
      '</div>'+
      '<div class="hdr-kpis">'+
        '<div class="hdr-kpi"><div class="kv" style="color:'+cfCol+';">'+(monthCF>=0?'+':'')+'$'+fmt(monthCF)+'</div><div class="kl">Cash Flow / Mo</div></div>'+
        '<div class="hdr-divider"></div>'+
        '<div class="hdr-kpi"><div class="kv" style="color:#2563eb;">'+fmtK(gn('f-market')-gn('f-purchase'))+'</div><div class="kl">Instant Equity</div></div>'+
        '<div class="hdr-divider"></div>'+
        '<div class="hdr-kpi"><span class="badge" style="background:'+ltvBg+';color:'+ltvCol+';">LTV '+ltvPct+'%</span><div class="kl" style="margin-top:4px;">LTV</div></div>'+
      '</div>'+
    '</div>';

  /* METRICS */
  var annRoePct=r1?(((annCF+annPrin+r1.appGain)/(entry||1))*100).toFixed(1):0;
  var instantEq=gn('f-market')-gn('f-purchase');  /* Instant Equity = שווי שוק פחות מחיר רכישה */
  $('metrics').innerHTML=
    mc('#ecfdf5','#059669','📈','ROE שנתי',annRoePct+'%','₪'+fmt(Math.round(annRoePct*entry*ils/100)))+
    mc('#eff6ff','#2563eb','💰','תזרים נטו',(monthCF>=0?'+':'')+'$'+fmt(monthCF),rentLabel+' | +'+gn('f-rent-growth')+'%/שנה')+
    mc('#f0f9ff','#0369a1','🏠','Instant Equity',fmtK(instantEq),instantEq>0?'רכישה מתחת לשוק ✓':'אין דיסקאונט')+
    mc('#f5f3ff','#7c3aed','🔒','שחיקת קרן שנה 1',fmtK(annPrin),'הון נצבר שקט (שפיצר)');

  function mc(bg,col,ico,lbl,val,sub){
    return '<div class="metric-card"><div class="mc-top"><div class="mc-icon" style="background:'+bg+';font-size:14px;">'+ico+'</div><span class="mc-label">'+lbl+'</span></div><div class="mc-val" style="color:'+col+';">'+val+'</div><div class="mc-sub">'+sub+'</div></div>';
  }

  /* YEAR CARDS — redesigned grid layout */
  var yc=['#2563eb','#059669','#7c3aed'],ycb=['#eff6ff','#ecfdf5','#f5f3ff'];
  var yhtml='';
  [5,10,15].forEach(function(yr,ci){
    var d=rows[yr];if(!d)return;
    var roeY=(((d.annCF+d.annPrin+d.appGain)/(entry||1))*100).toFixed(1);
    var origLoan=gn('f-loan-bal');
    yhtml+=
      '<div class="year-card">'+
        '<div class="yc-head">'+
          '<span class="yc-year" style="color:'+yc[ci]+';">שנה '+yr+'</span>'+
          '<span class="yc-roe" style="background:'+ycb[ci]+';color:'+yc[ci]+';">ROE '+roeY+'%</span>'+
        '</div>'+
        '<div class="yc-metrics">'+
          yci('Equity','#059669',fmtK(d.equity),fmtILS(d.equity,ils))+
          yci('יתרת חוב','#475569',fmtK(d.balance),'')+
          yci('קרן שנחזרה','#2563eb',fmtK(origLoan-d.balance),'')+
          yci('שכירות חודשית','#059669','$'+fmt(d.curRent),rentLabel)+
          yci('תזרים מצטבר',d.cumCF>=0?'#059669':'#e11d48',(d.cumCF>=0?'+':'')+fmtK(d.cumCF),fmtILS(d.cumCF,ils))+
          yci('Cash Flow / Mo',d.monthCF>=0?'#059669':'#e11d48','$'+fmt(d.monthCF),'')+
        '</div>'+
      '</div>';
  });
  $('year-cards').innerHTML=yhtml;

  function yci(lbl,col,val,sub){
    return '<div class="yc-item"><div class="yc-item-lbl">'+lbl+'</div><div class="yc-item-val" style="color:'+col+';">'+val+'</div>'+(sub?'<div class="yc-item-sub">'+sub+'</div>':'')+' </div>';
  }

  /* ROE CARD */
  var roeTotal=annCF+annPrin+(r1?r1.appGain:0);
  var roePct=entry>0?((roeTotal/entry)*100).toFixed(1):0;
  $('roe-card').innerHTML=
    '<div class="roe-head">'+
      '<div><div class="roe-title">ROE Analyzer — שנה 1 · שפיצר · '+rentLabel+'</div><div class="roe-sub">תשואה משולבת: תזרים + שחיקת קרן (שפיצר) + עליית ערך</div></div>'+
      '<div style="text-align:center;"><div class="roe-big">'+roePct+'%</div><div class="roe-ils">'+fmtILS(roeTotal,ils)+' / שנה</div></div>'+
    '</div>'+
    '<div class="roe-grid">'+
      ri('תזרים שנתי','#059669',annCF,entry,ils)+
      ri('שחיקת קרן (שפיצר)','#2563eb',annPrin,entry,ils)+
      ri('עליית ערך','#7c3aed',r1?r1.appGain:0,entry,ils)+
    '</div>'+
    '<div class="roe-formula">ROE = (CF + Principal + Appreciation) ÷ Entry Fee<br>     = ('+fmtK(annCF)+' + '+fmtK(annPrin)+' + '+fmtK(r1?r1.appGain:0)+') ÷ '+fmtK(entry)+' = <strong>'+roePct+'%</strong></div>';

  function ri(lbl,col,val,ef,ils2){
    var pct=ef>0?((val/ef)*100).toFixed(1):0;
    return '<div class="roe-item"><div class="ri-lbl">'+lbl+'</div><div class="ri-val" style="color:'+col+';">'+fmtK(val)+'</div><div class="ri-pct">'+fmtILS(val,ils2)+' · '+pct+'% ROE</div></div>';
  }

  /* ── DUAL CHART PANEL (CF + ROE) ── */
  var cfGrowthLabel=gn('f-rent-growth')>0?'+'+gn('f-rent-growth')+'%/שנה':'0%';
  var cfY15=rows[15]?rows[15].monthCF:0, cfY1=rows[1]?rows[1].monthCF:0;
  var roeY15=rows[15]?rows[15].roe:0, roeY1=rows[1]?rows[1].roe:0;
  var cfCol15=cfY15>=0?'#059669':'#e11d48';
  var roeCol15=roeY15>=20?'#059669':roeY15>=10?'#d97706':'#e11d48';

  $('dcp-panel').innerHTML=
    '<div class="dcp-header">'+
      '<div class="dcp-title">השפעת עליית שכירות '+cfGrowthLabel+' על תזרים ו-ROE לאורך 15 שנה</div>'+
      '<span class="dcp-badge" style="background:var(--green-lt);color:var(--green);">עליית שכירות: '+cfGrowthLabel+'</span>'+
    '</div>'+
    '<div class="dcp-stats">'+
      dcpStat('תזרים שנה 1','$'+fmt(cfY1),cfY1>=0?'#059669':'#e11d48')+
      dcpStat('תזרים שנה 15','$'+fmt(cfY15),cfCol15)+
      dcpStat('ROE שנה 1',roeY1.toFixed(1)+'%',roeY1>=15?'#059669':roeY1>=8?'#d97706':'#e11d48')+
      dcpStat('ROE שנה 15',roeY15.toFixed(1)+'%',roeCol15)+
    '</div>'+
    '<div class="dcp-body">'+
      '<div class="dcp-charts">'+
        '<div>'+
          '<div style="font-size:10px;font-weight:700;color:var(--text3);text-align:center;margin-bottom:8px;letter-spacing:.08em;text-transform:uppercase;">💸 תזרים חודשי ($)</div>'+
          '<div class="chart-wrap" id="wrap-cf"><canvas id="chart-cf" height="190"></canvas><div class="crosshair" id="cross-cf"></div></div>'+
        '</div>'+
        '<div>'+
          '<div style="font-size:10px;font-weight:700;color:var(--text3);text-align:center;margin-bottom:8px;letter-spacing:.08em;text-transform:uppercase;">📊 ROE שנתי (%)</div>'+
          '<div class="chart-wrap" id="wrap-roe-chart"><canvas id="chart-roe-line" height="190"></canvas><div class="crosshair" id="cross-roe"></div></div>'+
        '</div>'+
      '</div>'+
    '</div>';

  function dcpStat(lbl,val,col){
    return '<div class="dcp-stat"><div class="dcp-stat-lbl">'+lbl+'</div><div class="dcp-stat-val" style="color:'+col+';">'+val+'</div></div>';
  }

  /* ── CHARTS ── */
  setTimeout(function(){
    /* 1. Area: value vs balance (correct equity) */
    drawLineChart('chart-area','wrap-area','cross-area',rows,
      [{key:'value',  label:'שווי נכס',  color:'#2563eb'},
       {key:'balance',label:'יתרת חוב',  color:'#f43f5e'},
       {key:'equity', label:'Equity (שווי−חוב)',color:'#059669'}]
    );
    $('leg-area').innerHTML=
      '<div class="legend-item"><div class="ldot" style="background:#2563eb"></div>שווי נכס</div>'+
      '<div class="legend-item"><div class="ldot" style="background:#f43f5e"></div>יתרת חוב</div>'+
      '<div class="legend-item"><div class="ldot" style="background:#059669"></div>Equity = שווי − חוב</div>';

    /* 2. Sub-To vs S&P — correct baseline: gain above entry fee */
    var cmpData=rows.map(function(d){
      /* subto = equity + cumulative CF above entry fee basis
         at year 0: equity = marketVal − loanBal (instant equity), cumCF=0
         S&P gain starts at 0 year 0 */
      return{year:d.year,
        subto:Math.max(0,d.equity+Math.max(0,d.cumCF)),
        snpGain:Math.max(0,d.snpGain)};
    });
    drawLineChart('chart-compare','wrap-compare','cross-compare',cmpData,
      [{key:'subto',  label:'Sub-To (Equity+CF)',  color:'#2563eb'},
       {key:'snpGain',label:'S&P 500 (רווח על '+fmtK(entry)+')',color:'#059669'}]
    );
    $('leg-compare').innerHTML=
      '<div class="legend-item"><div class="ldot" style="background:#2563eb"></div>Sub-To</div>'+
      '<div class="legend-item"><div class="ldot" style="background:#059669"></div>S&P 500 ('+fmtK(entry)+' מושקעים)</div>';

    /* 3. Monthly CF — use real monthly values, proper scale */
    drawLineChart('chart-cf','wrap-cf','cross-cf',rows,
      [{key:'monthCF',label:'תזרים חודשי',color:cfY15>=0?'#059669':'#e11d48',mo:true}],
      190
    );

    /* 4. ROE % — real percentage values */
    var roeLineData=rows.slice(1).map(function(d){return{year:d.year,roe:d.roe};});
    drawLineChart('chart-roe-line','wrap-roe-chart','cross-roe',roeLineData,
      [{key:'roe',label:'ROE שנתי %',color:'#7c3aed',pct:true}],
      190
    );

    /* 5. Amortization */
    var amData=proj.shp.map(function(s){return{year:s.year,annualPrin:s.annualPrin,annualInt:s.annualInt,balance:s.balance};});
    if(amData.length>0)drawAmort('chart-amort','wrap-amort','cross-amort',amData);

  },50);

  /* MICRO CARDS */
  var mdefs=[
    {id:'mi-school',icon:'🎓',title:'חינוך',col:'#2563eb'},
    {id:'mi-crime', icon:'🛡️',title:'בטיחות',col:'#e11d48'},
    {id:'mi-growth',icon:'📊',title:'דמוגרפיה',col:'#7c3aed'},
    {id:'mi-jobs',  icon:'💼',title:'תעסוקה',col:'#d97706'},
  ];
  $('micro-row').innerHTML=mdefs.map(function(m){
    return '<div class="micro-card"><div class="micro-icon">'+m.icon+'</div><div class="micro-title" style="color:'+m.col+';">'+m.title+'</div><div class="micro-val" style="color:'+m.col+';">'+(gs(m.id)||'—')+'</div></div>';
  }).join('');

  /* RISK MATRIX */
  var rentRatio=piti>0?proj.baseRent/piti:0;
  var dom=gn('f-dom'),ilsNum=gn('f-ils');
  var risks=[
    {s:ltvNum>90?'fail':ltvNum>80?'warn':'pass',i:ltvNum>90?'✗':ltvNum>80?'⚠':'✓',t:'Due-on-Sale Risk',d:'LTV '+ltvNum.toFixed(1)+'% — '+(ltvNum>90?'סיכון גבוה, מומלץ LLC':ltvNum>80?'גבולי, שים לב':'בטוח ✓')},
    {s:ilsNum<3.2?'fail':ilsNum<3.5?'warn':'pass',i:ilsNum<3.2?'✗':ilsNum<3.5?'⚠':'✓',t:'שחיקת מטבע ILS',d:'שער ₪'+ilsNum+' — '+(ilsNum<3.2?'שחיקה חמורה':ilsNum<3.5?'כדאי לגדר':'סביר ✓')},
    {s:monthCF<0?'fail':monthCF<100?'warn':'pass',i:monthCF<0?'✗':monthCF<100?'⚠':'✓',t:'תזרים שלילי',d:'$'+fmt(monthCF)+'/mo '+(monthCF<0?'— שלילי!':monthCF<100?'— שולי מאוד':'✓')},
    {s:rentRatio>=1.1?'pass':rentRatio>=1.0?'warn':'fail',i:rentRatio>=1.1?'✓':rentRatio>=1.0?'⚠':'✗',t:'DSCR (כיסוי PITI)',d:'DSCR '+rentRatio.toFixed(2)+' — '+(rentRatio>=1.1?'מצוין':rentRatio>=1.0?'גבולי':'לא מכסה!')},
    {s:dom>60?'fail':dom>30?'warn':'pass',i:dom>60?'✗':dom>30?'⚠':'✓',t:'Vacancy Risk',d:dom+' ימים — '+(dom>60?'שוק קשה':dom>30?'מעל ממוצע':'שוק פעיל ✓')},
    {s:'warn',i:'⚠',t:'ריכוזיות',d:'נכס יחיד — מומלץ פיזור גיאוגרפי'},
  ];
  var rhtml='<div class="risk-title">Risk Matrix — Due Diligence אוטומטי</div><div class="risk-grid">';
  risks.forEach(function(r){rhtml+='<div class="risk-item '+r.s+'"><span class="ri-icon">'+r.i+'</span><div><div class="ri-title">'+r.t+'</div><div class="ri-desc">'+r.d+'</div></div></div>';});
  $('risk-section').innerHTML=rhtml+'</div>';
}

render();
window.addEventListener('resize',function(){setTimeout(render,80);});
</script>
</body>
</html>
