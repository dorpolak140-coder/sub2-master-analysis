<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Underwriter Pro v3.2</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap');
:root{
  --bg:#f8fafc;--surface:#fff;--surface2:#f1f5f9;
  --border:#e2e8f0;--border2:#cbd5e1;
  --text:#0f172a;--text2:#475569;--text3:#94a3b8;
  --blue:#2563eb;--blue-lt:#eff6ff;--blue-md:#bfdbfe;
  --green:#059669;--green-lt:#ecfdf5;
  --red:#e11d48;--red-lt:#fff1f2;
  --amber:#d97706;--amber-lt:#fffbeb;
  --purple:#7c3aed;--purple-lt:#f5f3ff;
  --font:'DM Sans',system-ui,sans-serif;
  --mono:'DM Mono',monospace;
  --r:10px;--r-lg:14px;
  --sh:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --sh-md:0 4px 14px rgba(0,0,0,.09);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px}
body{font-family:var(--font);background:var(--bg);color:var(--text);direction:rtl;display:flex;height:100vh;overflow:hidden}
input,select{font-family:var(--font)}
input[type=number]::-webkit-inner-spin-button{-webkit-appearance:none}
input[type=number]{-moz-appearance:textfield}
::-webkit-scrollbar{width:4px;height:4px}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px}

/* ── SIDEBAR ── */
.sidebar{width:290px;min-width:290px;height:100vh;background:var(--surface);border-left:1px solid var(--border);overflow-y:auto;display:flex;flex-direction:column;flex-shrink:0}
.sb-logo{padding:15px 18px 12px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-shrink:0}
.sb-logo .lm{width:30px;height:30px;background:var(--blue);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sb-logo .lt{font-size:13px;font-weight:700}
.sb-logo .ls{font-size:10px;color:var(--text3)}
.sb-body{padding:14px;display:flex;flex-direction:column;gap:12px}
.sb-sec{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:12px;box-shadow:var(--sh)}
.sb-sec-title{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:10px;display:flex;align-items:center;gap:4px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px}
.field{display:flex;flex-direction:column;gap:3px}
.field label{font-size:10px;font-weight:500;color:var(--text2)}
.field label.blue{color:var(--blue)}
.field label.green{color:var(--green)}
.field label.orange{color:var(--amber)}
.inp{width:100%;padding:6px 8px;border:1.5px solid var(--border);border-radius:8px;font-size:12px;color:var(--text);background:var(--surface);outline:none;transition:.15s;font-family:var(--mono)}
.inp:focus{border-color:var(--blue);box-shadow:0 0 0 3px rgba(37,99,235,.1)}
.inp.blue-inp{border-color:var(--blue-md);background:var(--blue-lt)}
.inp.green-inp{border-color:#86efac;background:var(--green-lt)}
.inp.orange-inp{border-color:#fcd34d;background:var(--amber-lt)}
.inp.full{width:100%}
/* rent toggle */
.rent-toggle{display:flex;border-radius:8px;overflow:hidden;border:1.5px solid var(--border);margin-bottom:8px}
.rent-btn{flex:1;padding:7px 4px;font-size:11px;font-weight:600;text-align:center;cursor:pointer;border:none;background:var(--surface2);color:var(--text3);transition:.15s;font-family:var(--font)}
.rent-btn.active-market{background:var(--surface2);color:var(--text);border-bottom:2.5px solid var(--text2)}
.rent-btn.active-s8{background:var(--green-lt);color:var(--green);border-bottom:2.5px solid var(--green)}
.rent-lbl{font-size:10px;font-weight:700;text-align:center;margin-bottom:7px}
/* shpitzer box */
.shp-box{background:var(--blue-lt);border:1px solid var(--blue-md);border-radius:8px;padding:8px 10px;margin-top:8px}
.shp-row{display:flex;justify-content:space-between;font-size:11px;margin-bottom:3px}
.shp-label{color:var(--blue);font-weight:500}
.shp-val{font-family:var(--mono);font-weight:700;color:var(--blue)}

/* ── MAIN ── */
.main{flex:1;height:100vh;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px;min-width:0}
.dash-hdr{background:var(--surface);border:1px solid var(--border);border-radius:var(--r-lg);padding:16px 20px;display:flex;justify-content:space-between;align-items:center;box-shadow:var(--sh);flex-wrap:wrap;gap:12px}
.dash-hdr h1{font-size:20px;font-weight:800;letter-spacing:-.02em}
.dash-hdr .sub{font-size:11px;color:var(--text3);margin-top:2px}
.hdr-kpis{display:flex;gap:20px;align-items:center}
.hdr-kpi{text-align:center}
.hdr-kpi .kv{font-size:20px;font-weight:800;font-family:var(--mono);line-height:1}
.hdr-kpi .kl{font-size:10px;color:var(--text3);letter-spacing:.06em;margin-top:2px;font-weight:600;text-transform:uppercase}
.hdr-divider{width:1px;height:36px;background:var(--border)}
.badge{display:inline-flex;align-items:center;padding:4px 10px;border-radius:20px;font-size:12px;font-weight:700}
.maturity-bar{background:var(--blue-lt);border:1px solid var(--blue-md);border-radius:var(--r);padding:8px 12px;display:flex;align-items:center;gap:10px;margin-top:8px}
.mat-label{font-size:10px;color:var(--blue);font-weight:600}
.mat-val{font-size:13px;font-weight:800;font-family:var(--mono);color:var(--blue)}
.mat-prog{flex:1;height:6px;background:var(--blue-md);border-radius:3px;overflow:hidden}
.mat-prog-inner{height:100%;background:var(--blue);border-radius:3px}
/* metric cards */
.metrics-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.metric-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-lg);padding:14px 16px;box-shadow:var(--sh);transition:.2s transform,.2s box-shadow}
.metric-card:hover{transform:translateY(-2px);box-shadow:var(--sh-md)}
.mc-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.mc-icon{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center}
.mc-label{font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3)}
.mc-val{font-size:20px;font-weight:800;font-family:var(--mono);line-height:1;margin-bottom:3px}
.mc-sub{font-size:10px;color:var(--text3)}
/* year cards */
.year-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.year-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-lg);padding:16px;box-shadow:var(--sh)}
.yc-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;padding-bottom:8px;border-bottom:1px solid var(--border)}
.yc-year{font-size:13px;font-weight:700}
.yc-roe{font-size:11px;font-weight:700;padding:3px 8px;border-radius:12px}
.yc-metrics{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.yc-item{background:var(--surface2);border-radius:8px;padding:8px 10px}
.yc-item-lbl{font-size:9px;color:var(--text3);font-weight:600;letter-spacing:.05em;text-transform:uppercase;margin-bottom:3px}
.yc-item-val{font-size:14px;font-weight:800;font-family:var(--mono)}
.yc-item-sub{font-size:10px;color:var(--text3);font-family:var(--mono)}
/* ROE */
.roe-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-lg);padding:18px;box-shadow:var(--sh)}
.roe-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px;flex-wrap:wrap;gap:10px}
.roe-title{font-size:14px;font-weight:700}
.roe-sub{font-size:11px;color:var(--text3);margin-top:2px}
.roe-big{font-size:32px;font-weight:800;font-family:var(--mono);color:var(--blue);line-height:1}
.roe-ils{font-size:12px;color:var(--text3)}
.roe-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:12px}
.roe-item{background:var(--surface2);border-radius:var(--r);padding:10px}
.ri-lbl{font-size:10px;color:var(--text3);margin-bottom:4px}
.ri-val{font-size:17px;font-weight:800;font-family:var(--mono)}
.ri-pct{font-size:10px;color:var(--text3)}
.roe-formula{background:var(--blue-lt);border:1px solid var(--blue-md);border-radius:var(--r);padding:9px 12px;font-size:11px;color:var(--blue);font-family:var(--mono);line-height:1.7}
/* charts */
.charts-2col{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.chart-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-lg);padding:16px;box-shadow:var(--sh)}
.chart-card .ct{font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);text-align:center;margin-bottom:10px}
.chart-wrap{position:relative;cursor:crosshair}
canvas{display:block;width:100%!important}
/* ── REDESIGNED CF/ROE chart panel ── */
.dual-chart-panel{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-lg);padding:0;box-shadow:var(--sh);overflow:hidden}
.dcp-header{padding:14px 18px 0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:8px}
.dcp-title{font-size:13px;font-weight:700;color:var(--text)}
.dcp-badge{font-size:10px;font-weight:700;padding:3px 9px;border-radius:12px}
.dcp-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-top:1px solid var(--border);border-bottom:1px solid var(--border);margin-top:12px}
.dcp-stat{padding:10px 14px;border-left:1px solid var(--border);text-align:center}
.dcp-stat:last-child{border-left:none}
.dcp-stat-lbl{font-size:9px;color:var(--text3);font-weight:600;letter-spacing:.06em;text-transform:uppercase;margin-bottom:3px}
.dcp-stat-val{font-size:16px;font-weight:800;font-family:var(--mono)}
.dcp-body{padding:14px 16px 14px}
.dcp-charts{display:grid;grid-template-columns:1fr 1fr;gap:12px}
/* tooltip */
.chart-tooltip{position:fixed;pointer-events:none;z-index:9999;background:#1e293b;color:#f8fafc;border-radius:10px;padding:10px 14px;font-family:var(--font);font-size:12px;box-shadow:0 8px 24px rgba(0,0,0,.25);min-width:180px;opacity:0;transition:opacity .1s;border:1px solid rgba(255,255,255,.08)}
.chart-tooltip.visible{opacity:1}
.tt-title{font-size:11px;font-weight:600;color:#94a3b8;margin-bottom:7px;padding-bottom:6px;border-bottom:1px solid rgba(255,255,255,.1)}
.tt-row{display:flex;justify-content:space-between;align-items:center;gap:14px;margin-bottom:4px}
.tt-row:last-child{margin-bottom:0}
.tt-label{font-size:11px;color:#cbd5e1;display:flex;align-items:center;gap:5px}
.tt-dot{width:7px;height:7px;border-radius:2px;flex-shrink:0}
.tt-val{font-size:12px;font-weight:700;font-family:var(--mono)}
.crosshair{position:absolute;top:0;width:1px;background:rgba(37,99,235,.2);pointer-events:none;display:none}
.legend{display:flex;flex-wrap:wrap;gap:10px;margin-top:8px;justify-content:center}
.legend-item{display:flex;align-items:center;gap:4px;font-size:10px;color:var(--text2)}
.ldot{width:8px;height:8px;border-radius:2px}
.micro-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.micro-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-lg);padding:14px;box-shadow:var(--sh);display:flex;flex-direction:column;align-items:center;text-align:center}
.micro-icon{font-size:22px;margin-bottom:6px}
.micro-title{font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:4px}
.micro-val{font-size:20px;font-weight:800;font-family:var(--mono)}
.risk-card{background:var(--surface);border:1.5px solid var(--border);border-radius:var(--r-lg);padding:18px;box-shadow:var(--sh)}
.risk-title{font-size:14px;font-weight:700;margin-bottom:12px}
.risk-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.risk-item{border-radius:var(--r);padding:11px 13px;display:flex;align-items:flex-start;gap:9px;border:1.5px solid transparent}
.risk-item.pass{background:#f0fdf4;border-color:#86efac}
.risk-item.fail{background:#fff1f2;border-color:#fca5a5}
.risk-item.warn{background:#fffbeb;border-color:#fcd34d}
.ri-icon{font-size:15px;flex-shrink:0;margin-top:1px}
.ri-title{font-size:11px;font-weight:700}
.ri-desc{font-size:10px;color:var(--text2);margin-top:2px;line-height:1.4}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.fu{animation:fadeUp .35s ease both}
.fu2{animation-delay:.06s}.fu3{animation-delay:.12s}.fu4{animation-delay:.18s}.fu5{animation-delay:.24s}.fu6{animation-delay:.30s}
@media(max-width:1100px){.metrics-row{grid-template-columns:1fr 1fr}.charts-2col{grid-template-columns:1fr}.dcp-charts{grid-template-columns:1fr}.micro-row{grid-template-columns:1fr 1fr}.risk-grid{grid-template-columns:1fr 1fr}}
@media(max-width:780px){.sidebar{display:none}.year-cards{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="chart-tooltip" id="tt"></div>

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar">
  <div class="sb-logo">
    <div class="lm"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
    <div><div class="lt">Underwriter Pro</div><div class="ls">Sub-To Analysis Engine v3.2</div></div>
  </div>
  <div class="sb-body">
    <div class="sb-sec">
      <div class="sb-sec-title">🏠 נכס ושווי</div>
      <div class="field" style="margin-bottom:8px"><label>כתובת הנכס</label><input class="inp full" id="f-address" type="text" value="Main St, Texas" oninput="render()"/></div>
      <div class="grid2">
        <div class="field"><label>שנת בנייה</label><input class="inp" id="f-year-built" type="number" value="1998" oninput="render()"/></div>
        <div class="field"><label>מחיר רכישה $</label><input class="inp" id="f-purchase" type="number" value="320000" oninput="render()"/></div>
      </div>
      <div class="grid2" style="margin-top:7px">
        <div class="field"><label>שווי שוק $</label><input class="inp" id="f-market" type="number" value="365000" oninput="render()"/></div>
        <div class="field"><label class="blue">Entry Fee $</label><input class="inp blue-inp" id="f-entry" type="number" value="19000" oninput="render()"/></div>
      </div>
    </div>
    <div class="sb-sec">
      <div class="sb-sec-title">📋 מימון — לוח שפיצר</div>
      <div class="grid2">
        <div class="field"><label>יתרת חוב $</label><input class="inp" id="f-loan-bal" type="number" value="280000" oninput="render()"/></div>
        <div class="field"><label class="blue">ריבית שנתית %</label><input class="inp blue-inp" id="f-rate" type="number" value="5.875" step="0.01" oninput="render()"/></div>
      </div>
      <div class="field" style="margin-top:7px"><label>מועד פירעון</label><input class="inp full" id="f-maturity" type="date" value="2053-10-01" oninput="render()"/></div>
      <div class="shp-box">
        <div class="shp-row"><span class="shp-label">תשלום חודשי (P+I)</span><span class="shp-val" id="shp-payment">—</span></div>
        <div class="shp-row"><span class="shp-label">ריבית חודשית שנה 1</span><span class="shp-val" id="shp-int1">—</span></div>
        <div class="shp-row"><span class="shp-label">קרן חודשית שנה 1</span><span class="shp-val" id="shp-prin1">—</span></div>
        <div class="shp-row"><span class="shp-label">סה"כ ריבית חיים</span><span class="shp-val" id="shp-total-int">—</span></div>
      </div>
    </div>
    <div class="sb-sec">
      <div class="sb-sec-title">💸 הוצאות חודשיות</div>
      <div class="grid2">
        <div class="field"><label>ארנונה $</label><input class="inp" id="f-taxes" type="number" value="450" oninput="render()"/></div>
        <div class="field"><label>ביטוח $</label><input class="inp" id="f-insurance" type="number" value="120" oninput="render()"/></div>
      </div>
      <div class="grid3" style="margin-top:7px">
        <div class="field"><label>HOA $</label><input class="inp" id="f-hoa" type="number" value="50" oninput="render()"/></div>
        <div class="field"><label class="orange">Capex $</label><input class="inp orange-inp" id="f-capex" type="number" value="150" oninput="render()"/></div>
        <div class="field"><label class="orange">Other $</label><input class="inp orange-inp" id="f-other" type="number" value="100" oninput="render()"/></div>
      </div>
    </div>
    <div class="sb-sec">
      <div class="sb-sec-title">🏷️ הכנסות שכירות</div>
      <div class="rent-toggle">
        <button class="rent-btn" id="btn-market" onclick="setRentMode('market')">🏠 שכירות שוק</button>
        <button class="rent-btn active-s8" id="btn-s8" onclick="setRentMode('s8')">📋 Section 8</button>
      </div>
      <div class="rent-lbl" id="rent-active-label"><span style="background:var(--green-lt);color:var(--green);padding:2px 10px;border-radius:6px;">✓ חישוב לפי Section 8</span></div>
      <div class="grid2">
        <div class="field"><label>שוק (Market) $</label><input class="inp" id="f-rent-market" type="number" value="2400" oninput="render()"/></div>
        <div class="field"><label class="green">Section 8 $</label><input class="inp green-inp" id="f-rent-s8" type="number" value="2750" oninput="render()"/></div>
      </div>
      <div class="grid2" style="margin-top:7px">
        <div class="field"><label>DOM (ימי שוק)</label><input class="inp" id="f-dom" type="number" value="14" oninput="render()"/></div>
        <div class="field"><label class="green">עליית שכירות %/שנה</label><input class="inp green-inp" id="f-rent-growth" type="number" value="2" step="0.5" oninput="render()"/></div>
      </div>
    </div>
    <div class="sb-sec">
      <div class="sb-sec-title">🌍 Macro &amp; Currency</div>
      <div class="grid2">
        <div class="field"><label>שער ILS ₪</label><input class="inp" id="f-ils" type="number" value="3.7" step="0.01" oninput="render()"/></div>
        <div class="field"><label>עליית ערך %/שנה</label><input class="inp" id="f-appr" type="number" value="3" step="0.1" oninput="render()"/></div>
      </div>
      <div class="field" style="margin-top:7px">
        <label>S&amp;P 500 תשואה %/שנה</label>
        <input class="inp" id="f-snp" type="number" value="10" step="0.5" oninput="render()"/>
      </div>
    </div>
    <div class="sb-sec">
      <div class="sb-sec-title">📊 Micro Data</div>
      <div class="grid2">
        <div class="field"><label>בתי-ספר</label><input class="inp" id="mi-school" type="text" value="8/10" oninput="render()"/></div>
        <div class="field"><label>פשיעה</label><input class="inp" id="mi-crime" type="text" value="A-" oninput="render()"/></div>
      </div>
      <div class="grid2" style="margin-top:7px">
        <div class="field"><label>צמיחה</label><input class="inp" id="mi-growth" type="text" value="+150%" oninput="render()"/></div>
        <div class="field"><label>אבטלה</label><input class="inp" id="mi-jobs" type="text" value="3.4%" oninput="render()"/></div>
      </div>
    </div>
  </div>
</aside>

<!-- ══ MAIN ══ -->
<main class="main">
  <div id="dash-hdr" class="fu"></div>
  <div id="metrics" class="metrics-row fu fu2"></div>
  <div id="year-cards" class="year-cards fu fu3"></div>
  <div id="roe-card" class="roe-card fu fu4"></div>
  <!-- Charts row 1: equity + S&P -->
  <div class="charts-2col fu fu5">
    <div class="chart-card">
      <div class="ct">📈 שווי נכס מול יתרת חוב — שפיצר</div>
      <div class="chart-wrap" id="wrap-area"><canvas id="chart-area" height="210"></canvas><div class="crosshair" id="cross-area"></div></div>
      <div class="legend" id="leg-area"></div>
    </div>
    <div class="chart-card">
      <div class="ct">💹 Sub-To vs S&P 500 — על ה-Entry Fee</div>
      <div class="chart-wrap" id="wrap-compare"><canvas id="chart-compare" height="210"></canvas><div class="crosshair" id="cross-compare"></div></div>
      <div class="legend" id="leg-compare"></div>
    </div>
  </div>
  <!-- Charts row 2: CF + ROE redesigned panel -->
  <div class="dual-chart-panel fu fu5" id="dcp-panel"></div>
  <!-- Amortization -->
  <div class="chart-card fu fu5">
    <div class="ct">🔢 לוח שפיצר שנתי — קרן וריבית לאורך זמן</div>
    <div class="chart-wrap" id="wrap-amort"><canvas id="chart-amort" height="190"></canvas><div class="crosshair" id="cross-amort"></div></div>
    <div class="legend">
      <div class="legend-item"><div class="ldot" style="background:#2563eb"></div>קרן שנתית</div>
      <div class="legend-item"><div class="ldot" style="background:#f43f5e"></div>ריבית שנתית</div>
    </div>
